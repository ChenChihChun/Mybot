<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_dialog_info"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar"
        android:usesCleartextTraffic="true">

        <!-- Main Activity for permissions setup -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Expense List Activity -->
        <activity android:name=".ExpenseActivity" android:exported="false" />

        <!-- Add Expense Activity -->
        <activity android:name=".AddExpenseActivity" android:exported="false" />

        <!-- Report Activity -->
        <activity android:name=".ReportActivity" android:exported="false" />

        <!-- Todo Activity -->
        <activity android:name=".TodoActivity" android:exported="false" />

        <!-- Add Todo Activity -->
        <activity android:name=".AddTodoActivity" android:exported="false" />

        <!-- Fitness Activities -->
        <activity android:name=".FitnessActivity" android:exported="false" />
        <activity android:name=".FitnessProfileActivity" android:exported="false" />
        <activity android:name=".WorkoutDetailActivity" android:exported="false" />
        <activity android:name=".FitnessProgressActivity" android:exported="false" />

        <!-- Calendar Activities -->
        <activity android:name=".CalendarActivity" android:exported="false" />
        <activity android:name=".AddCalendarEventActivity" android:exported="false" />

        <!-- Screen Capture Permission Activity (transparent) -->
        <activity
            android:name=".CapturePermissionActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Floating Capture Service -->
        <service
            android:name=".FloatingCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- FileProvider for APK install -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Boot Receiver -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Daily Reminder Receiver -->
        <receiver
            android:name=".ReminderReceiver"
            android:exported="false" />

        <!-- Todo Deadline Reminder Receiver -->
        <receiver
            android:name=".TodoReminderReceiver"
            android:exported="false" />

        <!-- Fitness Reminder Receiver -->
        <receiver
            android:name=".FitnessReminderReceiver"
            android:exported="false" />

    </application>

</manifest>
